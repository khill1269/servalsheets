# ServalSheets Terraform Configuration Example
# Copy this file to terraform.tfvars and customize for your environment

# Deployment Environment
environment = "dev"
aws_region  = "us-east-1"

# Container Configuration
ecr_repository_url        = "050752643237.dkr.ecr.us-east-1.amazonaws.com/servalsheets/mcp-server"
image_tag                 = "latest"
container_port            = 8000

# Cognito Integration
cognito_user_pool_id = "us-east-1_d6Q1t6bUi"
cognito_client_id    = "5ro2o67qejkbgd6857ee521r93"

# Bedrock Integration
bedrock_guardrail_id      = "rur8hed14y0b"
bedrock_guardrail_version = "1"

# Network Configuration
vpc_cidr             = "10.0.0.0/16"
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24"]

# Compute Configuration
cpu                  = 1024 # 256, 512, 1024, 2048, 4096, 8192, 16384
memory               = 2048 # MB, must match CPU value
desired_count        = 2    # Keep at least 2 for HA
min_capacity         = 2
max_capacity         = 10
target_cpu_utilization    = 70
target_memory_utilization = 75

# Health Check Configuration
health_check_path              = "/health/live"
health_check_interval          = 30
health_check_timeout           = 5
health_check_healthy_threshold = 2
health_check_unhealthy_threshold = 3

# Monitoring and Logging
enable_monitoring          = true
enable_container_insights  = true
cloudwatch_alarms_enabled  = true
log_retention_days         = 30

# Alarm Thresholds
high_cpu_threshold    = 85
high_memory_threshold = 85
error_rate_threshold  = 5

# Security
enable_waf           = true
enable_xray_tracing  = false

# Optional: SNS Topic for Alarms
# alarm_sns_topic_arn = "arn:aws:sns:us-east-1:123456789012:ops-alerts"

# Optional: Custom Domain (requires ACM certificate)
# domain_name    = "mcp.example.com"
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"

# Secrets Manager Configuration
secrets_manager_prefix = "servalsheets"

# Resource Tags
tags = {
  Owner          = "platform-team"
  CostCenter     = "engineering"
  Application    = "servalsheets-mcp"
  Repository     = "github.com/anthropics/servalsheets"
  ManagedBy      = "terraform"
}

# ========================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# ========================================

# Uncomment and modify for STAGING
# environment                = "staging"
# desired_count              = 3
# max_capacity               = 15
# high_cpu_threshold         = 80
# target_cpu_utilization     = 65
# enable_xray_tracing        = true
# log_retention_days         = 60

# Uncomment and modify for PRODUCTION
# environment                        = "prod"
# desired_count                      = 3
# min_capacity                       = 3
# max_capacity                       = 20
# cpu                                = 2048
# memory                             = 4096
# target_cpu_utilization             = 60
# target_memory_utilization          = 65
# high_cpu_threshold                 = 75
# high_memory_threshold              = 80
# enable_xray_tracing                = true
# enable_container_insights          = true
# log_retention_days                 = 90
# domain_name                        = "mcp-prod.example.com"
# certificate_arn                    = "arn:aws:acm:us-east-1:123456789012:certificate/prod-cert-id"
# alarm_sns_topic_arn                = "arn:aws:sns:us-east-1:123456789012:prod-ops-alerts"
