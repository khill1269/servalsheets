{
  "name": "@serval/mcp-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Transport-agnostic MCP runtime helpers and routing policy for ServalSheets",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
