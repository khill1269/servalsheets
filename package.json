{
  "name": "@serval/sheets",
  "version": "2.0.0",
  "type": "module",
  "description": "Production-grade MCP server for Google Sheets with 25 tools and 407 actions. AQUI-VR certified with A+ compliance.",
  "keywords": [
    "mcp",
    "google-sheets",
    "spreadsheet",
    "api",
    "ai",
    "claude",
    "anthropic"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/khill1269/servalsheets",
  "repository": {
    "type": "git",
    "url": "https://github.com/khill1269/servalsheets"
  },
  "bugs": {
    "url": "https://github.com/khill1269/servalsheets/issues"
  },
  "author": "Serval Inc <contact@serval.ai>",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/src/server.js",
  "exports": {
    ".": "./dist/src/server.js",
    "./http": "./dist/src/http-server.js",
    "./types": "./dist/src/index.d.ts"
  },
  "bin": {
    "servalsheets": "./bin/servalsheets.js"
  },
  "scripts": {
    "build": "tsc --build --force && node scripts/post-build.mjs",
    "build:incremental": "tsc --build && node scripts/post-build.mjs",
    "build:watch": "tsc --build --watch",
    "start": "node dist/src/server.js",
    "start:http": "node dist/src/http-server.js",
    "dev": "npm run build:watch & npm run start",
    "lint": "eslint src tests --max-warnings 0",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:fast": "vitest run --include 'tests/**/*.test.ts' --exclude 'tests/integration/**' --exclude 'tests/audit/**'",
    "test:integration": "vitest run tests/integration",
    "test:audit": "vitest run tests/audit",
    "typecheck": "tsc --noEmit",
    "verify:build": "npm run build && npm run typecheck && npm run test:fast",
    "verify": "npm run typecheck && npm run lint && npm run test:fast && npm run check:drift && npm run check:placeholders && npm run check:debug-prints && npm run check:silent-fallbacks && npm run validate:alignment",
    "verify:safe": "npm run typecheck && npm run test:fast && npm run check:drift && npm run check:placeholders && npm run check:debug-prints && npm run check:silent-fallbacks && npm run validate:alignment",
    "check:drift": "node scripts/check-schema-drift.mjs",
    "check:integration-wiring": "node scripts/check-integration-wiring.mjs",
    "check:mutation-actions": "node scripts/check-mutation-actions.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "check:debug-prints": "node scripts/check-debug-prints.mjs",
    "check:silent-fallbacks": "node scripts/check-silent-fallbacks.mjs",
    "check:file-sizes": "bash scripts/check-file-sizes.sh",
    "schema:commit": "node scripts/schema-commit.mjs",
    "validate:alignment": "npm run test -- tests/contracts/schema-handler-alignment.test.ts --reporter=verbose",
    "validate:audit": "node scripts/validate-audit.mjs",
    "gates": "npm run check:drift && npm run check:integration-wiring && npm run check:mutation-actions && npm run check:placeholders && npm run check:debug-prints && npm run check:silent-fallbacks && npm run validate:alignment",
    "audit:coverage": "vitest run tests/audit/action-coverage.test.ts",
    "audit:perf": "vitest run tests/audit/performance-profile.bench.ts",
    "audit:memory": "vitest run tests/audit/memory-leaks.test.ts",
    "audit:gate": "bash scripts/audit-gate.sh",
    "audit:snapshot": "node scripts/generate-health-snapshot.ts",
    "audit:full": "npm run audit:coverage && npm run audit:perf && npm run audit:memory && npm run audit:gate && npm run audit:snapshot",
    "clean": "tsc --build --clean && rm -rf dist node_modules",
    "prepublishOnly": "npm run verify:build && npm run check:file-sizes"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.5",
    "@google-cloud/bigquery": "^7.8.0",
    "@google-cloud/storage": "^7.8.0",
    "@google-cloud/vision": "^4.10.0",
    "@googleapis/drive": "^8.11.2",
    "@googleapis/docs": "^7.2.0",
    "@googleapis/sheets": "^11.2.0",
    "@googleapis/slides": "^6.2.0",
    "@modelcontextprotocol/sdk": "^1.2.1",
    "@serval/core": "^0.1.0",
    "ably": "^1.3.0",
    "api-gateway": "^2.0.0",
    "big.js": "^6.2.2",
    "bull": "^4.14.2",
    "csv-parser": "^3.0.0",
    "decimal.js": "^10.4.3",
    "diff-match-patch": "^20240101.0.0",
    "duckdb": "^1.0.0",
    "duckdb-wasm": "^1.28.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "fast-csv": "^4.3.6",
    "form-data": "^4.0.0",
    "google-auth-library": "^9.4.2",
    "google-p12-pem": "^4.0.1",
    "helmet": "^7.1.0",
    "http2-wrapper": "^2.2.1",
    "iconv-lite": "^0.6.3",
    "isolation-forest": "^1.1.0",
    "joi": "^17.13.3",
    "jose": "^5.4.1",
    "jsdom": "^24.1.1",
    "json-schema-to-typescript": "^13.1.2",
    "jwt-decode": "^4.0.0",
    "lru-cache": "^10.1.0",
    "md5": "^2.3.0",
    "minimatch": "^9.0.3",
    "moment-timezone": "^0.5.45",
    "node-fetch": "^3.4.0",
    "node-sqlite": "^0.6.4",
    "notionhq-client": "^2.2.14",
    "p-queue": "^7.4.1",
    "pino": "^8.20.0",
    "pino-pretty": "^10.3.2",
    "posthog": "^4.0.0",
    "psl": "^1.9.0",
    "redis": "^4.6.14",
    "rss": "^1.2.3",
    "saml2-js": "^2.4.0",
    "semver": "^7.6.3",
    "sleep": "^1.0.0",
    "spearman": "^0.6.0",
    "stripe": "^14.22.0",
    "tsv": "^0.3.1",
    "unzipper": "^0.10.15",
    "uuid": "^9.0.1",
    "voyage-ai": "^0.2.4",
    "xml-js": "^1.6.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bull": "^3.15.8",
    "@types/estree": "^1.0.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/md5": "^2.3.5",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.14.9",
    "@types/sinon": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.3",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@apple/passwordless-auth": "^1.0.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.2.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ]
}
