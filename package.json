{
  "name": "servalsheets",
  "version": "2.0.0",
  "description": "Production-grade MCP server for Google Sheets with 25 tools and 409 actions",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run generate:metadata",
    "build:cli": "tsc && node dist/cli.js",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:fast": "vitest --run tests/unit tests/contracts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "verify": "npm run typecheck && npm run lint && npm run test:run && npm run check:drift",
    "verify:safe": "npm run typecheck && npm run test:run && npm run check:drift",
    "verify:build": "npm run build && npm run verify",
    "schema:commit": "node scripts/generate-metadata.ts && npm run test:run -- tests/contracts && git add src/generated/ src/schemas/action-counts.ts src/mcp/completions.ts server.json 2>/dev/null || true",
    "check:drift": "node scripts/check-metadata-drift.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "check:debug-prints": "node scripts/check-debug-prints.mjs",
    "check:silent-fallbacks": "node scripts/check-silent-fallbacks.mjs",
    "check:integration-wiring": "node scripts/check-integration-wiring.mjs",
    "check:mutation-actions": "node scripts/check-mutation-actions.mjs",
    "validate:alignment": "node scripts/validate-alignment.mjs",
    "validate:audit": "node scripts/validate-audit-doc.mjs",
    "validate:dead-code": "node scripts/validate-dead-code.mjs",
    "gates": "npm run typecheck && npm run test:run && npm run check:drift",
    "audit:coverage": "node scripts/action-coverage.ts",
    "audit:perf": "vitest --run tests/audit/performance-profile.bench.ts",
    "audit:memory": "node scripts/memory-leaks.ts",
    "audit:snapshot": "node scripts/generate-health-snapshot.ts",
    "audit:gate": "bash scripts/audit-gate.sh",
    "audit:full": "npm run audit:coverage && npm run audit:perf && npm run audit:memory && npm run audit:gate && npm run audit:snapshot",
    "generate:metadata": "node scripts/generate-metadata.ts",
    "generate:state": "node .serval/generate-state.mjs",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "pretest": "npm run typecheck"
  },
  "keywords": [
    "mcp",
    "google-sheets",
    "api",
    "spreadsheet",
    "automation"
  ],
  "author": "ServalSheets Contributors",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.31.0",
    "@google-cloud/drive": "^7.0.0",
    "@google-cloud/bigquery": "^8.0.0",
    "@google-cloud/storage": "^8.0.0",
    "@google-cloud/monitoring": "^4.0.0",
    "@google-auth-library-nodejs": "^10.0.0",
    "@googleapis/sheets": "^6.0.0",
    "@googleapis/docs": "^6.0.0",
    "@googleapis/slides": "^6.0.0",
    "@googleapis/analytics": "^4.0.0",
    "@opentelemetry/api": "^1.10.0",
    "@opentelemetry/sdk-node": "^0.58.0",
    "@opentelemetry/sdk-trace-node": "^0.58.0",
    "@opentelemetry/exporter-jaeger-http": "^1.25.0",
    "@opentelemetry/exporter-zipkin": "^1.25.0",
    "@opentelemetry/api-logs": "^0.58.0",
    "@opentelemetry/sdk-logs": "^0.58.0",
    "@opentelemetry/resources": "^0.58.0",
    "@opentelemetry/semantic-conventions": "^0.58.0",
    "duckdb": "^1.14.0",
    "duckdb-wasm": "^1.29.0",
    "pyodide": "^0.27.0",
    "csv-parser": "^3.0.0",
    "xlsx": "^0.18.5",
    "papaparse": "^5.4.1",
    "zod": "^3.24.1",
    "node-saml": "^3.1.2",
    "jsonwebtoken": "^9.1.2",
    "bcrypt": "^5.1.1",
    "express": "^4.19.2",
    "compression": "^1.7.4",
    "helmet": "^7.2.0",
    "cors": "^2.8.5",
    "uuid": "^10.0.0",
    "p-queue": "^7.4.1",
    "p-pqueue": "^1.5.0",
    "ioredis": "^5.4.1",
    "redis": "^4.7.0",
    "stripe": "^22.0.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "joi": "^17.13.3",
    "axios": "^1.8.1",
    "got": "^14.10.1",
    "eventemitter3": "^5.0.1",
    "hyperformula": "^3.2.0",
    "js-base64": "^3.7.6",
    "date-fns": "^3.6.0",
    "sharp": "^0.33.5",
    "pdfkit": "^0.14.0",
    "canvas": "^2.11.2",
    "node-cache": "^5.1.2",
    "lru-cache": "^10.2.0",
    "tinypool": "^0.8.4",
    "workerpool": "^6.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/express": "^4.17.21",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@types/node-saml": "^1.4.2",
    "@types/bcrypt": "^5.0.2",
    "@types/papaparse": "^5.3.14",
    "@types/pdfkit": "^0.12.11",
    "@types/canvas": "^2.6.38",
    "typescript": "^5.5.4",
    "tsx": "^4.21.0",
    "vitest": "^2.1.2",
    "@vitest/ui": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.8.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "prettier": "^3.4.1"
  },
  "optionalDependencies": {
    "@opentelemetry/exporter-honeycomb": "^2.0.0"
  },
  "workspaces": [
    "packages/mcp-core",
    "packages/mcp-http",
    "packages/serval-core"
  ]
}
