{
  "name": "servalsheets",
  "version": "2.0.0",
  "description": "Production-grade MCP server for Google Sheets with 25 tools, 407 actions, multi-backend support.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest",
    "test:fast": "vitest run --no-coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test:fast && npm run check:drift",
    "verify:safe": "npm run typecheck && npm run test:fast && npm run check:drift",
    "verify:build": "npm run build && npm run typecheck && npm run test:fast",
    "schema:commit": "node scripts/schema-commit.mjs",
    "check:drift": "node scripts/check-drift.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "check:debug-prints": "node scripts/check-debug-prints.mjs",
    "check:silent-fallbacks": "node scripts/check-silent-fallbacks.mjs",
    "check:mutation-actions": "node scripts/check-mutation-actions.mjs",
    "check:integration-wiring": "node scripts/check-integration-wiring.mjs",
    "validate:alignment": "node scripts/validate-alignment.mjs",
    "validate:audit": "node scripts/validate-audit.mjs",
    "validate:dead-code": "node scripts/validate-dead-code.mjs",
    "audit:coverage": "vitest run tests/audit/action-coverage.test.ts --no-coverage",
    "audit:perf": "vitest run tests/audit/performance-profile.bench.ts --no-coverage",
    "audit:memory": "vitest run tests/audit/memory-leaks.test.ts --no-coverage",
    "audit:gate": "bash scripts/audit-gate.sh",
    "audit:snapshot": "node scripts/generate-health-snapshot.ts",
    "audit:full": "npm run audit:coverage && npm run audit:perf && npm run audit:memory && npm run audit:gate && npm run audit:snapshot",
    "gates": "node scripts/validation-gates.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@google-cloud/bigquery": "^7.10.0",
    "@google-cloud/dataflow": "^0.8.0",
    "googleapis": "^139.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.5"
  }
}
