# ========================================
# ServalSheets Production Deployment Configuration
# ========================================
# This is a comprehensive environment variable reference for production deployments
# across Google Cloud Run, AWS ECS, Railway, and self-hosted Kubernetes.
#
# IMPORTANT SECURITY NOTES:
# 1. Never commit actual secret values to version control
# 2. Use your platform's secret management (Secret Manager, Secrets Manager, etc.)
# 3. Always use HTTPS in production
# 4. Rotate secrets regularly (recommended: every 90 days)
# 5. Implement audit logging for secret access
#
# Generated: 2026-04-01
# ServalSheets Version: 2.0.0

# ============================================
# 1. CRITICAL PRODUCTION SECRETS
# ============================================
# These MUST be set in production. Never use default values.
# Generate new values: openssl rand -hex 32

JWT_SECRET=your-jwt-secret-here
STATE_SECRET=your-state-secret-here
ENCRYPTION_KEY=your-encryption-key-here
OAUTH_CLIENT_SECRET=your-oauth-client-secret-here
ADMIN_API_KEY=your-admin-api-key-here

# ============================================
# 2. ENVIRONMENT & DEPLOYMENT MODE
# ============================================

NODE_ENV=production
LOG_LEVEL=info

# Platform-specific identifiers
DEPLOYMENT_PLATFORM=cloudrun  # cloudrun | aws-ecs | railway | kubernetes | docker
DEPLOYMENT_REGION=us-central1
DEPLOYMENT_VERSION=2.0.0

# ============================================
# 3. SERVER & NETWORK CONFIGURATION
# ============================================

PORT=3000
HOST=0.0.0.0  # In production containers, listen on all interfaces

# MCP Transport mode (STDIO is default, HTTP for cloud deployments)
MCP_TRANSPORT=http

# Request timeout (milliseconds, default: 300000 = 5 minutes)
# Increase for long-running operations (imports, exports, analysis)
REQUEST_TIMEOUT_MS=300000

# Keep-alive timeout (milliseconds)
KEEP_ALIVE_TIMEOUT=65000

# ============================================
# 4. GOOGLE SHEETS & OAUTH
# ============================================

# Google OAuth credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth issuer and redirect URI
OAUTH_ISSUER=https://servalsheets.example.com
OAUTH_REDIRECT_URI=https://servalsheets.example.com/callback
OAUTH_CLIENT_ID=servalsheets

# Token TTL configuration (seconds)
ACCESS_TOKEN_TTL=3600         # 1 hour
REFRESH_TOKEN_TTL=2592000     # 30 days

# Optional: Google Cloud project for additional APIs
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ============================================
# 5. REDIS CONFIGURATION (CRITICAL)
# ============================================
# Redis is required for:
# - Session persistence across restarts
# - Task state in distributed deployments
# - Cache operations
# - Rate limiting
#
# Without Redis, features degrade to in-memory only (lost on restart)

REDIS_URL=redis://localhost:6379

# Redis cluster support (if using Redis Cluster)
# REDIS_CLUSTER_NODES=redis-node-1:6379,redis-node-2:6379,redis-node-3:6379

# Redis connection pooling
REDIS_MAX_CONNECTIONS=100
REDIS_CONNECTION_TIMEOUT=5000

# Session store backend (memory | redis)
# IMPORTANT: Use 'redis' for production
SESSION_STORE_TYPE=redis

# Session configuration
MAX_SESSIONS_PER_USER=10
SESSION_TTL_SECONDS=86400  # 24 hours

# ============================================
# 6. CORS & SECURITY
# ============================================

# Allowed CORS origins (comma-separated)
# CRITICAL: Configure this appropriately for your deployment
# Development: http://localhost:3000,http://127.0.0.1:3000
# Production: https://claude.ai,https://claude.com,https://your-app.com
CORS_ORIGINS=https://claude.ai,https://claude.com,https://servalsheets.example.com

# Allowed redirect URIs (comma-separated)
ALLOWED_REDIRECT_URIS=https://servalsheets.example.com/callback,https://api.servalsheets.example.com/callback

# HTTPS enforcement
ENFORCE_HTTPS=true

# Security headers
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000  # 1 year

# ============================================
# 7. AUTHENTICATION & SSO
# ============================================

# SAML 2.0 Support (Enterprise SSO)
# If configured, enables SAML authentication alongside OAuth

SAML_ENABLED=false
SAML_ENTRY_POINT=https://idp.example.com/saml/sso
SAML_ISSUER=urn:servalsheets:example
SAML_CALLBACK_URL=https://servalsheets.example.com/sso/callback
SAML_CERT=-----BEGIN CERTIFICATE-----
SAML_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_SIGNATURE_ALGORITHM=sha256
SAML_DIGEST_ALGORITHM=sha256

# SSO JWT token TTL (seconds)
SSO_JWT_TTL=3600

# SAML clock skew tolerance (seconds, default: 120)
# Accounts for server time drift between IdP and our server
SAML_ACCEPTED_CLOCK_SKEW_SECONDS=120

# ============================================
# 8. RATE LIMITING & QUOTAS
# ============================================

# Global rate limit (requests per minute)
RATE_LIMIT_GLOBAL=10000

# Per-user rate limit (requests per minute)
RATE_LIMIT_PER_USER=1000

# Per-IP rate limit (requests per minute)
RATE_LIMIT_PER_IP=5000

# API quota limits
QUOTA_SHEETS_API_REQUESTS_PER_MINUTE=300

# Circuit breaker configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=30000  # 30 seconds

# ============================================
# 9. CACHING & PERFORMANCE
# ============================================

CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=500
CACHE_TTL_MS=300000  # 5 minutes

# Request deduplication (prevents duplicate API calls)
DEDUPLICATION_ENABLED=true
DEDUPLICATION_TIMEOUT=30000
DEDUPLICATION_MAX_PENDING=1000

# Result caching
RESULT_CACHE_ENABLED=true
RESULT_CACHE_TTL=60000  # 1 minute
RESULT_CACHE_MAX_SIZE=5000

# Batch operation limits
BATCH_MAX_SIZE=100
BATCH_MAX_OPERATIONS_PER_REQUEST=1000

# ============================================
# 10. GOOGLE SHEETS API OPTIMIZATION
# ============================================

# Enable aggressive field masks (reduce response size)
ENABLE_AGGRESSIVE_FIELD_MASKS=true

# Enable request merging (combine overlapping ranges)
ENABLE_REQUEST_MERGING=true

# Enable parallel executor (concurrent operations)
ENABLE_PARALLEL_EXECUTOR=true

# Parallel executor configuration
PARALLEL_EXECUTOR_CONCURRENCY=20
PARALLEL_EXECUTOR_MAX_RANGE_SIZE=10000

# ============================================
# 11. FEATURE FLAGS
# ============================================

# Data filtering with batch operations
ENABLE_DATAFILTER_BATCH=true

# Table API appends
ENABLE_TABLE_APPENDS=true

# Payload validation
ENABLE_PAYLOAD_VALIDATION=true

# Apps Script trigger compatibility (for legacy clients)
ENABLE_APPSSCRIPT_TRIGGER_COMPAT=false

# Legacy SSE endpoints (deprecated, use Streamable HTTP instead)
ENABLE_LEGACY_SSE=false

# Tools list changed notifications
ENABLE_TOOLS_LIST_CHANGED_NOTIFICATIONS=false

# Checkpoints for resumable workflows
ENABLE_CHECKPOINTS=true
CHECKPOINT_DIR=/var/lib/servalsheets/checkpoints

# ============================================
# 12. EXTERNAL INTEGRATIONS
# ============================================

# BigQuery configuration (optional)
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=servalsheets_analytics

# Anthropic AI (for analysis features)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (for semantic search)
VOYAGE_API_KEY=...

# Federation: Remote MCP servers
MCP_FEDERATION_SERVERS=https://remote-server-1.example.com,https://remote-server-2.example.com

# ============================================
# 13. OBSERVABILITY & MONITORING
# ============================================

# OpenTelemetry configuration
OTEL_SERVICE_NAME=servalsheets
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_TIMEOUT=30000

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Tracing
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1  # Sample 10% of requests for cost efficiency

# Logging
LOG_LEVEL=info
LOG_FORMAT=json  # json | text
LOG_DESTINATION=stdout
LOG_RETENTION_DAYS=30

# Cloud-specific logging
# Google Cloud Logging
GCP_LOGGING_ENABLED=true

# AWS CloudWatch
AWS_CLOUDWATCH_ENABLED=true
AWS_LOG_GROUP=/ecs/servalsheets
AWS_LOG_STREAM_PREFIX=production

# ============================================
# 14. HEALTH CHECKS & READINESS
# ============================================

# Health check endpoints
HEALTH_CHECK_PATH=/health/live
READINESS_CHECK_PATH=/health/ready
STARTUP_CHECK_PATH=/health/startup

# Health check timeouts (milliseconds)
HEALTH_CHECK_TIMEOUT=5000

# Startup probe grace period (seconds)
STARTUP_GRACE_PERIOD=300  # 5 minutes to initialize

# ============================================
# 15. DEPLOYMENT-SPECIFIC SETTINGS
# ============================================

# Google Cloud Run
GCR_SERVICE_ACCOUNT=servalsheets-sa
GCR_PROJECT_ID=your-gcp-project-id
GCR_REGION=us-central1
GCR_MAX_INSTANCES=10
GCR_MIN_INSTANCES=1

# AWS ECS
ECS_CLUSTER_NAME=production
ECS_SERVICE_NAME=servalsheets
ECS_TASK_DEFINITION=servalsheets
ECS_DESIRED_COUNT=3
AWS_REGION=us-east-1

# Railway
RAILWAY_SERVICE_ID=your-railway-service-id
RAILWAY_ENVIRONMENT=production

# Kubernetes
K8S_NAMESPACE=production
K8S_DEPLOYMENT_NAME=servalsheets
K8S_REPLICAS=3
K8S_RESOURCE_MEMORY=2Gi
K8S_RESOURCE_CPU=2000m

# Docker
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=servalsheets
DOCKER_IMAGE_TAG=latest

# ============================================
# 16. DATABASE SETTINGS
# ============================================

# PostgreSQL (optional, for operational data)
# POSTGRES_URL=postgresql://user:password@localhost:5432/servalsheets
# POSTGRES_POOL_SIZE=20
# POSTGRES_POOL_IDLE_TIMEOUT=30000

# MongoDB (optional, for flexible data storage)
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/servalsheets

# ============================================
# 17. BACKUP & RECOVERY
# ============================================

# Snapshot/backup storage
SNAPSHOT_STORAGE_TYPE=gcs  # gcs | s3 | local
SNAPSHOT_STORAGE_BUCKET=servalsheets-backups
SNAPSHOT_STORAGE_PREFIX=prod/

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Automated backup schedule (cron expression)
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# ============================================
# 18. COMPLIANCE & SECURITY POLICIES
# ============================================

# Data residency requirements
DATA_RESIDENCY_REGION=us-central1

# Encryption at rest
ENCRYPTION_AT_REST_ENABLED=true
ENCRYPTION_KEY_PROVIDER=kms  # kms | local

# Data retention policies
DATA_RETENTION_DAYS=90

# Audit logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_DESTINATION=gcs  # gcs | s3 | cloudwatch

# GDPR compliance
GDPR_ENABLED=true

# ============================================
# 19. DEVELOPMENT/DEBUG SETTINGS (Disabled in Production)
# ============================================

# Debug mode (NEVER enable in production)
DEBUG=false

# Verbose logging (use sparingly in production)
VERBOSE=false

# Mock mode (for testing without external APIs)
MOCK_EXTERNAL_APIS=false

# Metrics debug output
METRICS_DEBUG=false

# ============================================
# 20. DOCUMENTATION & SETUP COMMANDS
# ============================================

# Generate required secrets:
#   JWT_SECRET:      openssl rand -hex 32
#   STATE_SECRET:    openssl rand -hex 32
#   ENCRYPTION_KEY:  openssl rand -hex 32
#
# Setup checklist:
#   1. Generate all required secrets (see above)
#   2. Configure OAuth application in Google Cloud Console
#   3. Set up Redis instance (production requirement)
#   4. Configure CORS origins for your domain
#   5. Set up SSL/TLS certificate (handled by platform)
#   6. Enable audit logging
#   7. Test health check endpoints
#   8. Configure monitoring and alerting
#   9. Set up backup and recovery procedures
#   10. Document all configuration changes
#
# Deployment verification:
#   - Health check: curl https://servalsheets.example.com/health/live
#   - Readiness: curl https://servalsheets.example.com/health/ready
#   - Metrics: curl https://servalsheets.example.com/metrics
#   - API test: curl -H "Authorization: Bearer YOUR_TOKEN" https://servalsheets.example.com/tools/list
